# ======================================
# Game Tracker 环境配置文件
# 复制为 .env 文件后修改
# ======================================

# --------------------------------------
# 安全设置（必填）
# --------------------------------------
# 用于JWT签名，请使用随机字符串（至少32位）
# 生成命令: openssl rand -hex 32
SECRET_KEY=your-super-secret-key-change-this-in-production

# --------------------------------------
# 应用设置
# --------------------------------------
# 调试模式（生产环境请设为 false）
DEBUG=false

# --------------------------------------
# 数据库配置（二选一）
# --------------------------------------

# 选项1: SQLite（推荐个人使用，零配置）
DATABASE_URL=sqlite+aiosqlite:///app/data/gametracker.db

# 选项2: PostgreSQL（推荐生产环境）
# 需要先创建数据库和用户
# DATABASE_URL=postgresql+asyncpg://用户名:密码@localhost/gametracker

# --------------------------------------
# Steam API 配置（可选）
# --------------------------------------
# 用于同步Steam游戏库，不配置则只能手动添加
# 获取地址: https://steamcommunity.com/dev/apikey
STEAM_API_KEY=

# --------------------------------------
# CORS 跨域配置
# --------------------------------------
# 允许访问的前端地址
CORS_ORIGINS=["http://localhost","http://localhost:5173"]

# --------------------------------------
# 高级配置（一般无需修改）
# --------------------------------------
# Token过期时间（分钟，默认7天）
# ACCESS_TOKEN_EXPIRE_MINUTES=10080

# API请求超时时间（秒）
# API_TIMEOUT=30
